// Get unique tags and count
function getCategories() {
  const tagCount: Record<string, number> = {};
  blogPosts.forEach(post => {
    post.tags.forEach(tag => {
      tagCount[tag] = (tagCount[tag] || 0) + 1;
    });
  });

  return Object.entries(tagCount)
    .sort(([,a], [,b]) => b - a)
    .slice(0, 8);
}

