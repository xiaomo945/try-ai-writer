# AI Provider Configuration
# Choose which AI provider to use: "claude" or "deepseek"
AI_PROVIDER=deepseek

# Claude API (from Anthropic)
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# NextAuth Configuration
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://tryaiwriter.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (for Apple ID login)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Creem payment (for paid subscriptions and credits, register at https://creem.io)
# CREEM_ENV: "test" for sandbox/test mode, "production" for live payments
# Test mode uses Creem test API keys (creem_test_xxx) - no real charges
# Production mode uses live API keys (creem_live_xxx) - real charges apply
CREEM_ENV=test
CREEM_API_KEY=creem_test_xxx

# Creem Product IDs - Subscription Plans
CREEM_PRODUCT_PRO=prod_3TGoHetTyl8m6N5d3ByY2v
CREEM_PRODUCT_MAX=prod_9LujLG243g7iUygjeiNuR
CREEM_PRODUCT_TEAM=prod_5WDywB0e9VrvcRHaxLZs7L

# Creem Product IDs - Credits Packages
# Small: $5 for 50 credits
# Medium: $12 for 150 credits
# Large: $35 for 500 credits
CREEM_PRODUCT_CREDITS_SMALL=prod_2jdbmtUU12bibnln4M6JaH
CREEM_PRODUCT_CREDITS_MEDIUM=prod_3oRgBJN3WSUnPdLgbMybUw
CREEM_PRODUCT_CREDITS_LARGE=prod_1051GdMUHkuttWBAlPkI8Y

# Webhook secret for verifying Creem payment notifications
CREEM_WEBHOOK_SECRET=your-creem-webhook-secret-here
