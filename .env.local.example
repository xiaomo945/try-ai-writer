# AI 模型选择：deepseek | claude | mock（默认 mock，不花钱）
AI_PROVIDER=mock

# DeepSeek API（国产，便宜，中文好）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Claude API（海外，贵，英文写作质量最高）
CLAUDE_API_KEY=your-claude-api-key-here

NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://tryaiwriter.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe 支付（用于付费订阅）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx

# Stripe Price IDs（在 Stripe Dashboard 创建 Products & Prices 后填入）
# USD 定价
STRIPE_PRICE_PRO_USD=price_pro_usd_placeholder
STRIPE_PRICE_MAX_USD=price_max_usd_placeholder
STRIPE_PRICE_TEAM_USD=price_team_usd_placeholder
# CNY 定价
STRIPE_PRICE_BASIC_CNY=price_basic_cny_placeholder
STRIPE_PRICE_PRO_CNY=price_pro_cny_placeholder
STRIPE_PRICE_MAX_CNY=price_max_cny_placeholder
STRIPE_PRICE_TEAM_CNY=price_team_cny_placeholder
