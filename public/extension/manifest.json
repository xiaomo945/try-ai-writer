{
  "manifest_version": 3,
  "name": "Try AI Writer Assistant",
  "version": "1.0.0",
  "description": "AI-powered writing assistant — generate, edit, and improve content anywhere on the web.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://tryaiwriter.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.svg",
      "48": "icon48.svg",
      "128": "icon128.svg"
    }
  },
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://tryaiwriter.com"
  }
}